# Neon PostgreSQL connection string.
# Use the DEV branch connection string here; production uses its own branch.
# Migrations connect directly with this URL, so prefer Neon's *direct/unpooled*
# connection string (the app runtime uses the Neon serverless driver adapter).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Password for the seeded demo user (dev only). Optional — the seed falls back
# to a built-in dev value if unset. The seed refuses to run when
# NODE_ENV=production regardless.
SEED_DEMO_PASSWORD=""
